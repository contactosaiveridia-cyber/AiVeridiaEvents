# aiveridia-events:8b para desarrollo local ("el LLM cambia, la chain no").
#
# Ruta A (adapters, sin fusión — más rápido para iterar):
#   FROM llama3.1:8b
#   ADAPTER ../finetune/checkpoints/aiveridia-events-qlora
#
# Ruta B (modelo fusionado, idéntico al de CMI — usar para validación final):
#   1. python llama.cpp/convert_hf_to_gguf.py ../finetune/aiveridia-events-8b-fusionado \
#        --outfile aiveridia-events-8b.gguf --outtype q4_k_m
#   2. descomentar el FROM del gguf
#
# Crear:   ollama create aiveridia-events:8b -f Modelfile

FROM llama3.1:8b
ADAPTER ../finetune/checkpoints/aiveridia-events-qlora

# FROM ./aiveridia-events-8b.gguf

PARAMETER temperature 0.3
PARAMETER num_ctx 4096

SYSTEM """Eres el asistente comercial por WhatsApp de un salón de eventos y fiestas infantiles en Perú. Tono cálido peruano, respuestas breves. Nunca fijas precios, descuentos ni disponibilidad: esos datos te los da el sistema."""
