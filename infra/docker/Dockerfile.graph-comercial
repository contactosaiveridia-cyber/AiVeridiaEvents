# Bedrock AgentCore Runtime — grafo comercial (P1).
# AgentCore requiere linux/arm64:
#   docker buildx build --platform linux/arm64 \
#     -f infra/docker/Dockerfile.graph-comercial -t graph-comercial apps/agents
FROM --platform=linux/arm64 python:3.12-slim

WORKDIR /app
COPY pyproject.toml ./
COPY src ./src
RUN pip install --no-cache-dir -e .[cloud] bedrock-agentcore

ENV AIV_ENV=prod AIV_TIMERS=eventbridge
EXPOSE 8080
CMD ["python", "src/agentcore/app_comercial.py"]
