# ── Entorno ──────────────────────────────────────────────────────────────
AIV_ENV=dev                          # dev | staging | prod

# ── Base de datos (Supabase / Postgres) ──────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aiveridia
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM router ───────────────────────────────────────────────────────────
# prod: Bedrock Custom Model Import | dev: Ollama | escalación: Gemini
AIVERIDIA_EVENTS_MODEL_ARN=          # ARN del modelo fine-tuned en Bedrock CMI (vacío => fallback Llama 3.1 8B base)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=aiveridia-events:8b     # si no existe aún, el router degrada a llama3.1:8b / llama3.2
GEMINI_API_KEY=
AWS_REGION=us-east-1

# ── Reglas de negocio ────────────────────────────────────────────────────
AIV_UMBRAL_DESCUENTO=10              # % máximo de descuento sin interrupt() al dueño
AIV_TIMEOUT_COTIZACION_H=48          # escalera P1 (BPMN): PT48H
AIV_TIMEOUT_FINAL_H=168              # P7D
AIV_TIMEOUT_PAGO_H=24                # PT24H
AIV_TIMEOUT_PAGO_FINAL_H=48          # PT48H

# ── Borde y timers ───────────────────────────────────────────────────────
AIV_TIMERS=apscheduler               # null | apscheduler (dev) | eventbridge (prod)
AIV_DEDUP=postgres                   # postgres | memory (tests)
AIV_INTERNAL_TOKEN=dev-internal-token  # protege POST /internal/resume

# ── Canales ──────────────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Pagos ────────────────────────────────────────────────────────────────
CULQI_SECRET_KEY=
CULQI_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ── Observabilidad ───────────────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aiveridia-events-dev
